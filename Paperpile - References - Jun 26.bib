@ARTICLE{Bacolla2008-cu,
  title     = "Abundance and length of simple repeats in vertebrate genomes are
               determined by their structural properties",
  author    = "Bacolla, Albino and Larson, Jacquelynn E and Collins, Jack R and
               Li, Jian and Milosavljevic, Aleksandar and Stenson, Peter D and
