  journal   = "PLoS Genet.",
  publisher = "Public Library of Science (PLoS)",
  volume    =  2,
  number    =  3,
  pages     = "e41",
  abstract  = "The study of continuously varying, quantitative traits is
               important in evolutionary biology, agriculture, and medicine.
               Variation in such traits is attributable to many, possibly
               interacting, genes whose expression may be sensitive to the
               environment, which makes their dissection into underlying
