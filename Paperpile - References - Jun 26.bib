@ARTICLE{Sasani2026-sv,
  title       = "A family portrait of the genomic factors shaping tandem repeat
                 mutagenesis",
  author      = "Sasani, Thomas A and Goldberg, Michael E and Avvaru, Akshay K
                 and Nicholas, Thomas J and Neklason, Deborah W and Dolzhenko,
