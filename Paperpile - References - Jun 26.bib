@ARTICLE{Dobson2004-ks,
  title     = "The unique transcriptome through day 3 of human preimplantation
               development",
  author    = "Dobson, Anthony T and Raja, Rajiv and Abeyta, Michael J and
               Taylor, Theresa and Shen, Shehua and Haqq, Christopher and Pera,
