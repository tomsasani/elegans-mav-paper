}

@ARTICLE{Neville2026-pj,
  title       = "Mutation timing, accumulation and selection in the male
                 germline shape inheritance risk for developmental disorders",
  author      = "Neville, Matthew D C and Neuser, Sonja and Sanghvi, Rashesh and
                 Christopher, Joseph and Roberts, Kirsty and Smith, Katie and
                 O'Neill, Laura and Hayes, Joseph and Cagan, Alex and Hurles,
                 Matthew E and Goriely, Anne and Abou Jamra, Rami and Rahbari,
