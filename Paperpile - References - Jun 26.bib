@ARTICLE{Matsuba2013-sy,
  title     = "Temperature, stress and spontaneous mutation in Caenorhabditis
               briggsae and Caenorhabditis elegans",
  author    = "Matsuba, Chikako and Ostrow, Dejerianne G and Salomon, Matthew P
               and Tolani, Amit and Baer, Charles F",
  journal   = "Biol. Lett.",
  publisher = "The Royal Society",
  volume    =  9,
  number    =  1,
  pages     =  20120334,
  abstract  = "Mutation rate often increases with environmental temperature, but
               establishing causality is complicated. Asymmetry between
