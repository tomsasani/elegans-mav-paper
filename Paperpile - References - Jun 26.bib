@ARTICLE{Maksimov2023-jg,
  title    = "A novel quantitative trait locus implicates {Msh3} in the
              propensity for genome-wide short tandem repeat expansions in mice",
  author   = "Maksimov, Mikhail O and Wu, Cynthia and Ashbrook, David G and
              Villani, Flavia and Colonna, Vincenza and Mousavi, Nima and Ma,
