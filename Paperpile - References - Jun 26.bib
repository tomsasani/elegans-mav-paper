  language = "en"
}

@ARTICLE{Campbell2015-qj,
  title    = "Somatic mosaicism: implications for disease and transmission
              genetics",
  author   = "Campbell, Ian M and Shaw, Chad A and Stankiewicz, Pawel and
              Lupski, James R",
  journal  = "Trends Genet.",
  volume   =  31,
  number   =  7,
  pages    = "382--392",
  abstract = "Nearly all of the genetic material among cells within an organism
              is identical. However, single-nucleotide variants (SNVs), small
              insertions/deletions (indels), copy-number variants (CNVs), and
              other structural variants (SVs) continually accumulate as cells
              divide during development. This process results in an organism
              composed of countless cells, each with its own unique personal
              genome. Thus, every human is undoubtedly mosaic. Mosaic mutations
              can go unnoticed, underlie genetic disease or normal human
