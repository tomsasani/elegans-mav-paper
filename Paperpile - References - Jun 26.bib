@ARTICLE{Slyskova2011-fb,
  title     = "{DNA} damage and nucleotide excision repair capacity in healthy
               individuals",
  author    = "Slyskova, Jana and Naccarati, Alessio and Polakova, Veronika and
               Pardini, Barbara and Vodickova, Ludmila and Stetina, Rudolf and
