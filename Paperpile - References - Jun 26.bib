@ARTICLE{Alexandrov2020-ji,
  title    = "The repertoire of mutational signatures in human cancer",
  author   = "Alexandrov, Ludmil B and Kim, Jaegil and Haradhvala, Nicholas J
              and Huang, Mi Ni and Tian Ng, Alvin Wei and Wu, Yang and Boot,
              Arnoud and Covington, Kyle R and Gordenin, Dmitry A and Bergstrom,
