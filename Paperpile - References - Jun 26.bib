@ARTICLE{Visscher2006-sm,
  title     = "Assumption-free estimation of heritability from genome-wide
               identity-by-descent sharing between full siblings",
  author    = "Visscher, Peter M and Medland, Sarah E and Ferreira, Manuel A R
