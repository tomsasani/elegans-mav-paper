  journal  = "Mol. Biol. Evol.",
  volume   =  29,
  number   =  10,
  pages    = "2949--2955",
  abstract = "Estimates of the proportion of amino acid substitutions that have
              been fixed by selection (α) vary widely among taxa, ranging from
              zero in humans to over 50\% in Drosophila. This wide range may
              reflect differences in the efficacy of selection due to
